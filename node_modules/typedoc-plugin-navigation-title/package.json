{
  "name": "typedoc-plugin-navigation-title",
  "version": "1.2.3",
  "description": "TypeDoc plugin to set custom navigation title with @navigationTitle tag.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./extends/tsdoc.json": "./extends/tsdoc.json"
  },
  "files": [
    "dist",
    "extends",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "docs:readme": "node ./bin/cli docs generate:readme",
    "docs:cli": "npm run -s docs:cli:private && npm run -s docs:cli:public",
    "docs:cli:private": "node ./bin/cli docs generate:cli -c ./docs/cli/private/config.js",
    "docs:cli:public": "node ./bin/cli docs generate:cli -c ./docs/cli/public/config.js",
    "docs": "npm run -s docs:readme && npm run -s docs:cli",
    "example": "cd example && npm run -s docs",
    "example:preview": "npm run -s example && http-server ./example/docs/api -c-1",
    "lint": "node ./bin/cli lint",
    "lint:fix": "npm run -s lint -- --fix",
    "lint:markdown": "node ./bin/cli lint:markdown",
    "lint:markdown:fix": "npm run -s lint:markdown -- --fix",
    "release": "node ./bin/cli release",
    "changelog": "node ./bin/cli changelog",
    "git-hooks:reset": "node ./bin/cli git-hooks reset",
    "git-hooks:sync": "node ./bin/cli git-hooks sync",
    "test": "node ./bin/cli test run",
    "test:watch": "node ./bin/cli test",
    "test:ui": "npm run -s test:watch -- --ui --coverage.enabled=true",
    "test:coverage": "npm run -s test -- --coverage.enabled=true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/hperchec/typedoc-plugin-navigation-title.git"
  },
  "author": {
    "name": "Hervé Perchec",
    "url": "https://gitlab.com/herveperchec"
  },
  "license": "GPL-3.0-only",
  "bugs": {
    "url": "https://gitlab.com/hperchec/typedoc-plugin-navigation-title/issues"
  },
  "homepage": "https://gitlab.com/hperchec/typedoc-plugin-navigation-title",
  "keywords": [
    "typedoc",
    "typescript",
    "typedoc-plugin",
    "output",
    "navigation",
    "title",
    "tag"
  ],
  "dependencies": {
    "typedoc": "^0.28.12",
    "typedoc-plugin-navigation-hooks": "^1.1.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^9.0.4",
    "@vitest/coverage-v8": "^3",
    "@vitest/ui": "^3",
    "eslint-plugin-jsdoc": "^50.8.0",
    "eslint-plugin-tsdoc": "^0.5.0",
    "http-server": "^14.1.1",
    "juisy": "^2.0.1",
    "simple-git-hooks": "^2.13.1",
    "typescript-eslint": "^8.39.1",
    "vite-plugin-checker": "^0.11.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3",
    "vscode-region-parser": "^1.0.0"
  },
  "peerDependencies": {
    "typedoc": "^0.28.12",
    "typedoc-plugin-navigation-hooks": "^1.1.0"
  }
}
